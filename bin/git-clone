#! /usr/bin/env python3

import os
import sys
import getpass
import logging
import argparse
import subprocess

user = os.environ.get('GITHUB_USER') or getpass.getuser()

servers = {
  'codeberg': 'codeberg.org',
  'github': 'github.com',
}

parser = argparse.ArgumentParser(description='Clone git repos from server')
parser.add_argument('repos', metavar='repo', nargs='+', help='One or more repos')
parser.add_argument('-u', '--user', nargs='?', help=f'Server user (default: {user})')
parser.add_argument('-s', '--server', choices=servers.keys(), default='codeberg', help=f'Type of git server (default: codeberg)')
parser.add_argument('--http', action='store_true', help='Clone via http rather than ssh')
parser.add_argument('-d', '--dry-run', action='store_true', help='Do not execute git command(s)')
parser.add_argument('-v', '--verbose', action='count', help='Enable debugging')
args = parser.parse_args()

logging.basicConfig(format='%(asctime)s %(levelname)s %(pathname)s:%(lineno)d %(msg)s')
log = logging.getLogger()
log.setLevel(logging.INFO if args.dry_run else logging.WARNING - (args.verbose or 0)*10)

if args.user:
  user = args.user

if args.dry_run:
  log.info('Avoiding executing git commands due to --dry-run option')

"""
ssh://git@codeberg.org/mrbruno/gaming.git
"""

for repo in args.repos:
  repo = repo.rstrip('/')
  cmd = ['git', 'clone', 'https://' if args.http else 'git@']
  separator = '/' if args.http else ':'
  cmd[-1] += f'{servers[args.server]}{separator}{user}/{repo}.git'
  print(' '.join(cmd))
  if not args.dry_run:
    subprocess.run(cmd)
