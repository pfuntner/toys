#! /usr/bin/env python

import re
import sys
import json
import logging
import argparse

def parse(root, lines, prev_indent=0, parent=None, parent_key=None):
  while lines:
    line = lines[0]
    if line.strip():
      match = indentation_regexp.search(line)
      assert match, '{indentation.pattern!r} failed to parse {line!r}'.format(**locals())
      curr_indent = len(match.group(1))
      if curr_indent >= prev_indent:
        remain = match.group(2)
        match = id_with_colon_regexp.search(remain)
        kv = {}
        if match:
          line_type = 'id_with_colon'
          heading = match.group(1).strip()
          datum = match.group(2).strip() if match.group(2) else None
        else:
          match = id_with_spaces_regexp.search(remain)
          if match and ('  ' not in match.group(1).strip()):
            line_type = 'id_with_spaces'
            heading = match.group(1).strip()
            datum = match.group(2).strip()
          else:
            line_type = 'list_item'
            heading = None
            datum = remain.strip()
        if datum:
          match = kv_regexp.search(datum)
          if match:
            kv[match.group(1).strip()] = match.group(2).strip()
        log.debug('{prev_indent} {curr_indent} {line_type} heading={heading!r} datum={datum!r} kv={kv} line={line!r} root={root}'.format(**locals()))

        processed = False
        if border_regexp.search(heading or '-') and border_regexp.search(datum or '-'):
          lines.pop(0)
          log.debug('Ignoring border: {line!r}'.format(**locals()))
          processed = True
        elif heading:
          lines.pop(0)
          if root is None:
            root = {heading: datum}
            parent[parent_key] = root
            parse(root[heading], lines, prev_indent=curr_indent, parent=root, parent_key=heading)
          elif isinstance(root, dict):
            root[heading] = datum
            parse(root[heading], lines, prev_indent=curr_indent, parent=root, parent_key=heading)
          elif isinstance(root, list):
            root.append({heading: datum})
            parse(root[heading], lines, prev_indent=curr_indent, parent=root, parent_key=heading)
        if (not processed) and isinstance(root, list) and datum and (not heading):
          lines.pop(0)
          root.append(kv if kv else datum)
        else:
          log.info('Letting caller deal with {line}'.format(**locals()))
          break

        log.debug('root: {root}'.format(**locals()))
      else:
        log.info('Letting caller deal with {line}'.format(**locals()))
        break
    else:
      break

def normalize(root):
  if isinstance(root, list):
    for (pos, value) in enumerate(root):
      if isinstance(value, list) and (len(value) == 1):
        root[pos] = value[0]
    for value in root:
      normalize(value)
  elif isinstance(root, dict):
    for (key, value) in root.items():
      if isinstance(value, list) and (len(value) == 1):
        root[key] = value[0]
    for key in root:
      normalize(root[key])

parser = argparse.ArgumentParser(description='Read JSON from free form text')
parser.add_argument('-v', '--verbose', dest='verbose', action='store_true', help='Enable debugging')
args = parser.parse_args()

logging.basicConfig(format='%(asctime)s %(levelname)s %(pathname)s:%(lineno)d %(msg)s')
log = logging.getLogger()
log.setLevel(logging.DEBUG if args.verbose else logging.WARNING)

if sys.stdin.isatty():
  parser.error('stdin must be directed')

indentation_regexp = re.compile(r'^(\s*)(.*)$')
id_with_colon_regexp = re.compile(r'^([^:]+):(?:\s+(.*))?$')
id_with_spaces_regexp = re.compile(r'^(.+)\s{2,}(\S.*)$')
kv_regexp = re.compile(r'^([^=]+)=(.*)$')
border_regexp = re.compile('^\s*-(\s|-)*$')

root = [{}]
lines = sys.stdin.read().splitlines()

while lines:
  log.info('Starting to parse {lines}'.format(**locals()))
  parse(root[-1], lines)
  if lines and (not lines[0].strip()):
    log.info('Adding a new dictionary item due to blank line')
    lines.pop(0)
    if root[-1]:
      # last parse didn't add anything - no need to keep an empty dictionary
      root.append({})
  else:
    break

if lines:
  log.critical('Unable to parse {lines}'.format(**locals()))
  exit(1)

normalize(root)

print json.dumps(root, indent=2, sort_keys=True)
